---
import Base from '../layouts/Base.astro';
import { talks } from '../data/talks';

const byYear = talks.reduce<Record<string, typeof talks>>((acc, t) => {
  if (!acc[t.year]) acc[t.year] = [];
  acc[t.year].push(t);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

const badge: Record<string, string> = {
  keynote:    'Keynote',
  panel:      'Panel',
  conference: '',
  workshop:   'Workshop',
};
---

<Base
  title="Talks — Mritunjay Sharma"
  description="Conference talks and keynotes at KubeCon, Cloud Native SecurityCon, Open Source Summit, and more."
>
  <div class="wrap">
    <header class="page-header">
      <h1>Talks</h1>
      <p class="subtitle">
        8 talks across KubeCon, Cloud Native SecurityCon, Open Source Summit, and Wasm Day —
        covering container security, supply chain integrity, and Kubernetes policy.
      </p>
    </header>

    <div class="talk-years">
      {years.map(year => (
        <section class="year-block">
          <span class="label year-label">{year}</span>
          <div class="talk-list">
            {byYear[year].map(talk => (
              <a href={talk.url} target="_blank" rel="noopener" class="talk-row hover-row">
                <div class="talk-left">
                  {badge[talk.type] && (
                    <span class="talk-badge">{badge[talk.type]}</span>
                  )}
                  <p class="talk-title">{talk.title}</p>
                  <p class="talk-event">{talk.event}</p>
                </div>
                <span class="ext">↗</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Base>

<style>
  .wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.65;
    max-width: 58ch;
  }

  .talk-years {
    padding-top: 1rem;
  }

  .year-block {
    padding: 2rem 0 0;
  }

  .year-label {
    display: block;
    margin-bottom: 0.75rem;
  }

  .talk-list {
    display: flex;
    flex-direction: column;
  }

  .talk-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 0.75rem 1.1rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    margin-left: -0.875rem;
  }

  .talk-row:last-child { border-bottom: none; }

  .talk-left { flex: 1; }

  .talk-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.35rem;
  }

  .talk-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.3rem;
    line-height: 1.45;
    transition: color 0.15s;
  }

  .talk-row:hover .talk-title { color: var(--accent); }

  .talk-event {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--text-faint);
    margin: 0;
    letter-spacing: 0.03em;
  }

  .ext {
    font-size: 0.75rem;
    color: var(--text-faint);
    flex-shrink: 0;
    padding-top: 0.15rem;
    transition: color 0.15s;
  }

  .talk-row:hover .ext { color: var(--accent); }
</style>
