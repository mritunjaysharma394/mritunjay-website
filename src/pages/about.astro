---
import Base from '../layouts/Base.astro';
import { experience } from '../data/experience';
---

<Base
  title="About — Mritunjay Sharma"
  description="Senior Software Engineer at Chainguard working on AI systems and container security. CNCF contributor, KubeCon speaker, two-time Google Summer of Code alum."
>
  <div class="max-w-3xl mx-auto px-6 py-14">
    <div class="mb-12">
      <h1 class="text-2xl font-bold text-ink mb-2">About</h1>
    </div>

    <!-- Bio -->
    <section class="mb-14 prose prose-gray prose-sm max-w-none">
      <p>
        I'm a Senior Software Engineer working at the intersection of <strong>AI systems and container security</strong>. At <a href="https://chainguard.dev" target="_blank" rel="noopener">Chainguard</a>, I co-architect an agentic AI orchestration platform that automates 70% of secure package creation across a 2000+ image catalog. Before that, I built the foundational FIPS/secure container images that became Chainguard's core product — scaled from fewer than 50 to 500+ images in 14 months as part of a small team.
      </p>
      <p>
        I'm a two-time <strong>Google Summer of Code</strong> alum (CNCF 2021, RTEMS 2020), <strong>KubeCon speaker</strong> (8 talks across KubeCon EU/NA 2021–2024), and CNCF contributor with <a href="https://link.springer.com/chapter/10.1007/978-981-19-5292-0_29" target="_blank" rel="noopener">published research</a> on Kubernetes policy CRDs.
      </p>
      <p>
        Outside of work, I'm passionate about building AI projects, contributing to open source, and exploring how AI systems can be made more robust and reliable.
      </p>
    </section>

    <!-- Skills -->
    <section class="mb-14">
      <p class="section-title">Technical Skills</p>
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div>
          <p class="font-medium text-ink mb-1">Languages</p>
          <p class="text-muted">Go, Python, C, C++, Rust, JavaScript, SQL</p>
        </div>
        <div>
          <p class="font-medium text-ink mb-1">AI / ML Systems</p>
          <p class="text-muted">Agentic AI orchestration, vLLM, LLM workload hardening, AI-native automation</p>
        </div>
        <div>
          <p class="font-medium text-ink mb-1">Container & Cloud-Native</p>
          <p class="text-muted">Kubernetes, Wolfi, melange, apko, Docker, Kyverno, Falco</p>
        </div>
        <div>
          <p class="font-medium text-ink mb-1">Supply Chain Security</p>
          <p class="text-muted">sigstore/cosign, SBOM, SLSA, FIPS, image signing & verification</p>
        </div>
        <div>
          <p class="font-medium text-ink mb-1">Tools & CI/CD</p>
          <p class="text-muted">GitHub Actions, Git, Linux, event-driven workflow automation</p>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-14">
      <p class="section-title">Experience</p>
      <div class="space-y-10">
        {experience.map(company => (
          <div>
            <div class="flex items-center gap-2 mb-4">
              <a
                href={company.companyUrl}
                target="_blank"
                rel="noopener"
                class="font-semibold text-ink hover:text-accent transition-colors text-sm"
              >
                {company.company}
              </a>
              <span class="text-muted text-xs">· {company.location}</span>
            </div>
            <div class="space-y-6 pl-4 border-l border-border">
              {company.roles.map(role => (
                <div>
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <p class="text-sm font-medium text-ink">{role.title}</p>
                    <p class="text-xs text-muted flex-shrink-0">{role.start} – {role.end}</p>
                  </div>
                  <ul class="space-y-1">
                    {role.bullets.map(bullet => (
                      <li class="text-sm text-muted leading-relaxed flex gap-2">
                        <span class="text-border mt-1.5">·</span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Publications -->
    <section class="mb-14">
      <p class="section-title">Publications</p>
      <a
        href="https://link.springer.com/chapter/10.1007/978-981-19-5292-0_29"
        target="_blank"
        rel="noopener"
        class="card block group"
      >
        <p class="text-sm font-semibold text-ink group-hover:text-accent transition-colors mb-1">
          A Survey on Kubernetes Policy Report CRD Kube-Bench Adapter
        </p>
        <p class="text-xs text-muted">
          Advances in Data and Information Sciences. Lecture Notes in Networks and Systems, vol 522. Springer, Singapore, 2022.
        </p>
      </a>
    </section>

    <!-- Education -->
    <section class="mb-14">
      <p class="section-title">Education</p>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-ink">JSS Academy of Technical Education</p>
          <p class="text-sm text-muted">B.Tech in Computer Science Engineering · CGPA 8.8</p>
        </div>
        <p class="text-xs text-muted flex-shrink-0">2018 – 2022</p>
      </div>
    </section>

    <!-- Recognition -->
    <section>
      <p class="section-title">Recognition</p>
      <ul class="space-y-2 text-sm text-muted">
        <li class="flex gap-2"><span class="text-border">·</span><span><strong class="text-ink">Tech Lead, Delivery India (Chainguard, 2025–2026)</strong> — Led a 9-person engineering team</span></li>
        <li class="flex gap-2"><span class="text-border">·</span><span><strong class="text-ink">Intern Program Lead (Chainguard, 2024–2025)</strong> — Mentored 3 interns and multiple engineers</span></li>
        <li class="flex gap-2"><span class="text-border">·</span><span><strong class="text-ink">LFX Mentor, Fall 2021</strong> — CNCF Kubernetes Policy Working Group</span></li>
        <li class="flex gap-2"><span class="text-border">·</span><span><strong class="text-ink">Winner, Smart India Hackathon 2020</strong> — Accessibility solution for the physically disabled</span></li>
        <li class="flex gap-2"><span class="text-border">·</span><span><strong class="text-ink">Two-time Google Summer of Code alum</strong> — CNCF (2021), RTEMS (2020)</span></li>
      </ul>
    </section>

  </div>
</Base>
