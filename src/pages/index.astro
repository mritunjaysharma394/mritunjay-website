---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter(p => p.featured);
---

<Base title="Mritunjay Sharma — Software Engineer & AI Systems Builder">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <div class="flex items-start gap-6">
        <img
          src="/avatar.png"
          alt="Mritunjay Sharma"
          class="w-16 h-16 rounded-full object-cover flex-shrink-0 mt-1"
        />
        <div>
          <h1 class="text-2xl font-bold text-ink mb-1">Mritunjay Sharma</h1>
          <p class="text-muted text-sm mb-4">Senior Software Engineer · Chainguard · Remote</p>
          <p class="text-ink leading-relaxed max-w-xl">
            I work at the intersection of <strong>AI systems and container security</strong>. At Chainguard, I co-architect an agentic AI orchestration platform automating secure package creation at scale. Previously built the foundational FIPS/secure container images that became Chainguard's core product.
          </p>
          <p class="text-ink leading-relaxed max-w-xl mt-3">
            Two-time Google Summer of Code alum, KubeCon speaker, and CNCF contributor with published research on Kubernetes policy CRDs.
          </p>
          <div class="flex items-center gap-4 mt-5 flex-wrap">
            <a href="mailto:mritunjaysharma394@gmail.com" class="text-sm text-accent hover:text-blue-800 transition-colors">
              mritunjaysharma394@gmail.com
            </a>
            <a href="https://github.com/mritunjaysharma394" target="_blank" rel="noopener" class="text-sm text-muted hover:text-ink transition-colors">GitHub</a>
            <a href="https://linkedin.com/in/mritunjay394" target="_blank" rel="noopener" class="text-sm text-muted hover:text-ink transition-colors">LinkedIn</a>
            <a href="https://twitter.com/mritunjay394" target="_blank" rel="noopener" class="text-sm text-muted hover:text-ink transition-colors">Twitter</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Currently -->
    <section class="py-12 border-b border-border">
      <p class="section-title">Currently</p>
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div class="flex gap-3">
          <span class="text-accent mt-0.5">→</span>
          <span class="text-ink">Building agentic AI orchestration systems at <a href="https://chainguard.dev" target="_blank" rel="noopener" class="link">Chainguard</a>, automating 70% of secure package creation across a 2000+ image catalog</span>
        </div>
        <div class="flex gap-3">
          <span class="text-accent mt-0.5">→</span>
          <span class="text-ink">Building <a href="https://github.com/mritunjaysharma394/llmwiki" target="_blank" rel="noopener" class="link">llmwiki</a> — a Go CLI implementing Andrej Karpathy's LLM Wiki concept</span>
        </div>
        <div class="flex gap-3">
          <span class="text-accent mt-0.5">→</span>
          <span class="text-ink">Contributing to open source and building more AI projects</span>
        </div>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="py-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-title mb-0">Featured Projects</p>
        <a href="/projects" class="text-xs text-muted hover:text-ink transition-colors">View all →</a>
      </div>
      <div class="space-y-4">
        {featuredProjects.map(project => (
          <div class="card group">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-semibold text-ink text-sm mb-1">
                  {project.github ? (
                    <a href={project.github} target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                      {project.title}
                    </a>
                  ) : project.url ? (
                    <a href={project.url} target="_blank" rel="noopener" class="hover:text-accent transition-colors">
                      {project.title}
                    </a>
                  ) : project.title}
                </h3>
                <p class="text-sm text-muted leading-relaxed">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {project.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <span class="text-xs text-muted flex-shrink-0">{project.year}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Recent Writing -->
    <section class="py-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-title mb-0">Recent Writing</p>
        <a href="/blog" class="text-xs text-muted hover:text-ink transition-colors">All posts →</a>
      </div>
      <div class="space-y-5">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="flex items-start justify-between gap-4 group">
            <div>
              <h3 class="text-sm font-medium text-ink group-hover:text-accent transition-colors leading-snug">
                {post.data.title}
              </h3>
              {post.data.excerpt && (
                <p class="text-sm text-muted mt-0.5 leading-snug line-clamp-1">{post.data.excerpt}</p>
              )}
            </div>
            <time class="text-xs text-muted flex-shrink-0">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </section>

    <!-- Talks teaser -->
    <section class="py-12">
      <div class="flex items-center justify-between mb-4">
        <p class="section-title mb-0">Speaking</p>
        <a href="/talks" class="text-xs text-muted hover:text-ink transition-colors">All talks →</a>
      </div>
      <p class="text-sm text-muted leading-relaxed">
        Spoken at <strong class="text-ink">KubeCon 2024, 2022, 2021</strong>, Cloud Native SecurityCon, Open Source Summit, and delivered a Guest Keynote at KubeCon EU 2021 with CNCF GM Priyanka Sharma. Topics span container security, supply chain integrity, Kubernetes policy, and open source onboarding.
      </p>
    </section>

  </div>
</Base>
