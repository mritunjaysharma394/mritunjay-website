---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featured = projects.filter(p => p.featured);

const ticker = 'Agentic AI · Container Security · Go · Kubernetes · vLLM · CNCF · Wolfi · GSoC · KubeCon · Supply Chain · Secure Images · Open Source · ';
---

<Base title="Mritunjay Sharma — Software Engineer">
  <div class="wrap">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-top">
        <img
          src="/avatar.png"
          alt="Mritunjay Sharma"
          class="avatar"
          data-a="1"
        />
        <div class="hero-text">
          <h1 data-a="1">Mritunjay Sharma</h1>
          <p class="role" data-a="2">
            Senior Software Engineer
            <span class="sep">·</span>
            <a href="https://chainguard.dev" target="_blank" rel="noopener">Chainguard</a>
            <span class="sep">·</span>
            Remote
          </p>
        </div>
      </div>

      <hr class="hero-rule" data-a="2" />

      <p class="bio" data-a="3">
        I work at the intersection of <strong>AI systems and container security</strong>.
        At Chainguard I co-architect an agentic AI orchestration platform that automates 70%
        of secure package creation across a 2000+ image catalog. Previously built the
        foundational FIPS and secure container images that became Chainguard's core product.
      </p>

      <p class="bio" data-a="4">
        Two-time Google Summer of Code alum, KubeCon speaker, and CNCF contributor
        with published research on Kubernetes policy CRDs.
      </p>

      <div class="hero-links" data-a="5">
        <a href="mailto:mritunjaysharma394@gmail.com">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </a>
        <a href="https://github.com/mritunjaysharma394" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          GitHub
        </a>
        <a href="https://linkedin.com/in/mritunjay394" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
        <a href="https://twitter.com/mritunjay394" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          Twitter
        </a>
      </div>
    </section>

    <!-- ── Tech ticker ────────────────────────────────────── -->
    <div class="ticker-wrap" data-a="6">
      <div class="marquee-wrap">
        <div class="marquee-track">
          <span class="ticker-text">{ticker}</span>
          <span class="ticker-text" aria-hidden="true">{ticker}</span>
          <span class="ticker-text" aria-hidden="true">{ticker}</span>
          <span class="ticker-text" aria-hidden="true">{ticker}</span>
        </div>
      </div>
    </div>

    <!-- ── Currently ─────────────────────────────────────── -->
    <section class="content-section">
      <span class="label">Currently</span>
      <ul class="curr-list">
        <li>Building agentic AI orchestration systems at <a class="a-link" href="https://chainguard.dev" target="_blank" rel="noopener">Chainguard</a> — automating 70% of secure package creation across a 2000+ image catalog</li>
        <li>Building <a class="a-link" href="https://github.com/mritunjaysharma394/llmwiki" target="_blank" rel="noopener">llmwiki</a>, a Go CLI implementing Andrej Karpathy's LLM Wiki concept</li>
        <li>Contributing to open source and building more AI projects</li>
      </ul>
    </section>

    <hr class="section-divider" />

    <!-- ── Selected work ─────────────────────────────────── -->
    <section class="content-section">
      <div class="section-head">
        <span class="label">Selected work</span>
        <a href="/projects" class="view-all">All projects →</a>
      </div>
      <div class="project-list">
        {featured.map((p, i) => (
          <a
            href={p.github ?? p.url ?? '#'}
            target="_blank"
            rel="noopener"
            class="project-row hover-row"
          >
            <div class="project-main">
              <span class="project-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <p class="project-title">{p.title}</p>
                <p class="project-desc">{p.description}</p>
                <div class="tag-row">
                  {p.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
            </div>
            <span class="project-year">{p.year}</span>
          </a>
        ))}
      </div>
    </section>

    <hr class="section-divider" />

    <!-- ── Writing ───────────────────────────────────────── -->
    <section class="content-section">
      <div class="section-head">
        <span class="label">Writing</span>
        <a href="/blog" class="view-all">All posts →</a>
      </div>
      <div class="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-row hover-row">
            <div>
              <p class="post-title">{post.data.title}</p>
              {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
            </div>
            <time class="post-date">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </section>

    <hr class="section-divider" />

    <!-- ── Speaking ──────────────────────────────────────── -->
    <section class="content-section" style="padding-bottom: 0;">
      <div class="section-head">
        <span class="label">Speaking</span>
        <a href="/talks" class="view-all">All talks →</a>
      </div>
      <p class="speaking-blurb">
        8 talks across <strong>KubeCon EU 2024 · 2022 · 2021</strong>, KubeCon NA 2021,
        Cloud Native SecurityCon, Open Source Summit, and Wasm Day. Guest Keynote at KubeCon EU 2021
        with CNCF GM Priyanka Sharma.
      </p>
    </section>

  </div>
</Base>

<style>
  .wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-top {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    filter: grayscale(15%);
  }

  .hero-text {
    flex: 1;
  }

  h1 {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 0.35rem;
  }

  .role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .role a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .role a:hover { color: var(--accent); }

  .sep {
    margin: 0 0.4em;
    opacity: 0.5;
  }

  .hero-rule {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 0 0 1.5rem;
  }

  .bio {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text);
    max-width: 60ch;
    margin: 0 0 0.85rem;
  }

  .bio strong { color: var(--text); font-weight: 500; }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .hero-links a {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .hero-links a:hover { color: var(--accent); }

  /* Ticker */
  .ticker-wrap {
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .ticker-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    padding-right: 2rem;
    white-space: nowrap;
  }

  /* Sections */
  .content-section {
    padding: 2.5rem 0;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .view-all {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.15s;
  }
  .view-all:hover { color: var(--accent); }

  .section-divider {
    height: 1px;
    background: var(--border);
    border: none;
    margin: 0;
  }

  /* Currently list */
  .curr-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .curr-list li {
    font-size: 0.875rem;
    color: var(--text);
    line-height: 1.65;
    padding-left: 1.1rem;
    position: relative;
  }

  .curr-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.75rem;
    top: 0.15em;
  }

  /* Projects */
  .project-list {
    display: flex;
    flex-direction: column;
    margin-top: 0.25rem;
  }

  .project-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0.75rem 1rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    margin-left: -0.875rem;
  }

  .project-row:last-child { border-bottom: none; }

  .project-main {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    flex: 1;
  }

  .project-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-faint);
    letter-spacing: 0.06em;
    margin-top: 0.2rem;
    flex-shrink: 0;
    min-width: 1.5rem;
  }

  .project-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.3rem;
    line-height: 1.4;
    transition: color 0.15s;
  }

  .project-row:hover .project-title { color: var(--accent); }

  .project-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .project-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-faint);
    flex-shrink: 0;
    padding-top: 0.2rem;
    letter-spacing: 0.04em;
  }

  /* Posts */
  .post-list {
    display: flex;
    flex-direction: column;
    margin-top: 0.25rem;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.875rem 0.75rem 0.875rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    margin-left: -0.875rem;
  }

  .post-row:last-child { border-bottom: none; }

  .post-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.25rem;
    line-height: 1.45;
    transition: color 0.15s;
  }

  .post-row:hover .post-title { color: var(--accent); }

  .post-excerpt {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-faint);
    flex-shrink: 0;
    padding-top: 0.2rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Speaking */
  .speaking-blurb {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 58ch;
    margin: 1rem 0 0;
  }

  .speaking-blurb strong {
    color: var(--text);
    font-weight: 500;
  }
</style>
