---
import Base from '../layouts/Base.astro';
import { projects } from '../data/projects';

const featured = projects.filter(p => p.featured);
const oss      = projects.filter(p => !p.featured);
---

<Base
  title="Projects — Mritunjay Sharma"
  description="AI systems, container security tools, and open source work."
>
  <div class="wrap">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="subtitle">
        Selected work in AI systems and open source. More at
        <a class="a-link" href="https://github.com/mritunjaysharma394" target="_blank" rel="noopener">
          github.com/mritunjaysharma394
        </a>.
      </p>
    </header>

    <!-- Featured -->
    <section class="proj-section">
      <span class="label section-label">Featured</span>
      <div class="proj-list">
        {featured.map((p, i) => (
          <div class="proj-row">
            <div class="proj-inner">
              <span class="proj-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="proj-body">
                <div class="proj-head">
                  <h2 class="proj-title">
                    {(p.github || p.url) ? (
                      <a href={p.github ?? p.url} target="_blank" rel="noopener">
                        {p.title}
                      </a>
                    ) : p.title}
                  </h2>
                  <span class="proj-year">{p.year}</span>
                </div>
                <p class="proj-desc">{p.description}</p>
                <div class="proj-foot">
                  <div class="tag-row">
                    {p.tags.map(t => <span class="tag">{t}</span>)}
                  </div>
                  <div class="proj-links">
                    {p.github && (
                      <a href={p.github} target="_blank" rel="noopener" class="ext-link">GitHub ↗</a>
                    )}
                    {p.url && p.url !== p.github && (
                      <a href={p.url} target="_blank" rel="noopener" class="ext-link">Live ↗</a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- OSS -->
    <section class="proj-section">
      <span class="label section-label">Open Source</span>
      <div class="proj-list">
        {oss.map((p, i) => (
          <div class="proj-row">
            <div class="proj-inner">
              <span class="proj-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="proj-body">
                <div class="proj-head">
                  <h2 class="proj-title">
                    {(p.github || p.url) ? (
                      <a href={p.github ?? p.url} target="_blank" rel="noopener">
                        {p.title}
                      </a>
                    ) : p.title}
                  </h2>
                  <span class="proj-year">{p.year}</span>
                </div>
                <p class="proj-desc">{p.description}</p>
                <div class="proj-foot">
                  <div class="tag-row">
                    {p.tags.map(t => <span class="tag">{t}</span>)}
                  </div>
                  <div class="proj-links">
                    {p.github && (
                      <a href={p.github} target="_blank" rel="noopener" class="ext-link">GitHub ↗</a>
                    )}
                    {p.url && p.url !== p.github && (
                      <a href={p.url} target="_blank" rel="noopener" class="ext-link">Live ↗</a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .proj-section {
    padding: 2.5rem 0 0;
  }

  .section-label {
    display: block;
    margin-bottom: 1.25rem;
  }

  .proj-list {
    display: flex;
    flex-direction: column;
  }

  .proj-row {
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 0;
    transition: background-color 0.15s;
  }
  .proj-row:last-child { border-bottom: none; }
  .proj-row:hover { background-color: var(--bg-subtle); margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }

  .proj-inner {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .proj-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-faint);
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
    flex-shrink: 0;
    min-width: 1.5rem;
  }

  .proj-body { flex: 1; }

  .proj-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  h2.proj-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
    margin: 0;
    line-height: 1.35;
  }

  .proj-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }
  .proj-title a:hover { color: var(--accent); }

  .proj-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--text-faint);
    flex-shrink: 0;
    letter-spacing: 0.04em;
    margin-top: 0.2rem;
  }

  .proj-desc {
    font-size: 0.8375rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 0 0.85rem;
  }

  .proj-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .proj-links {
    display: flex;
    gap: 0.75rem;
  }

  .ext-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.15s;
  }
  .ext-link:hover { color: var(--accent); }
</style>
