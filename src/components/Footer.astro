---
const year = new Date().getFullYear();
---

<footer>
  <div class="inner">
    <span class="copy">© {year} Mritunjay Sharma</span>
    <nav aria-label="Social links">
      <a href="mailto:mritunjaysharma394@gmail.com">Email</a>
      <a href="https://github.com/mritunjaysharma394"  target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/mritunjay394"  target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://twitter.com/mritunjay394"      target="_blank" rel="noopener">X</a>
    </nav>
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    border-top: 1px solid var(--border);
  }

  .inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  nav a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-faint);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  nav a:hover { color: var(--text); }
</style>
